void searchBook() {
    cout << "\nSearch by:\n1. ID\n2. Title\n3. Author\nChoice: ";
    int ch; cin >> ch; cin.ignore();

    string term;
    cout << "Enter search term: "; getline(cin, term);

    string sql;
    if (ch == 1) sql = "SELECT * FROM books WHERE bookId = " + term + ";";
    else if (ch == 2) sql = "SELECT * FROM books WHERE title LIKE '%" + term + "%';";
    else sql = "SELECT * FROM books WHERE author LIKE '%" + term + "%';";

    cout << "\n Search Results \n";
    sqlite3_stmt* stmt = nullptr;
    if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        bool found = false;
        while (sqlite3_step(stmt) == SQLITE_ROW) {
            found = true;
            cout << "ID: " << sqlite3_column_int(stmt, 0)
                 << " | " << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 1))
                 << " | " << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 2))
                 << " | " << (sqlite3_column_int(stmt, 4) ? "Available" : "Borrowed") << endl;
        }
        if (!found) cout << "No results found.\n";
    }
    if (stmt) sqlite3_finalize(stmt);
}

//  TRANSACTIONS
void issueBook() {
    if (currentUser.role == "Member") {
        cout << "Access Denied!\n";
        return;
    }

    int bookId, userId;
    cout << "\nEnter Book ID: ";
    cin >> bookId;
    cout << "Enter Borrower User ID: ";
    cin >> userId;
    cin.ignore();

    if (!canBorrow(userId)) return;

    // Check book availability safely
    bool available = false;
    sqlite3_stmt* stmt = nullptr;
    string q = "SELECT isAvailable FROM books WHERE bookId = " + to_string(bookId) + ";";

    if (sqlite3_prepare_v2(db, q.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW) {
            available = sqlite3_column_int(stmt, 0) == 1;
        }
    }
    if (stmt) sqlite3_finalize(stmt);

    if (!available) {
        cout << " Book not available or doesn't exist!\n";
        return;
    }

    string today = getCurrentDate();
    string R_day= getCurrentDate(7);
    string sql1 = "INSERT INTO transactions (bookId, userId, issueDate, dueDate) VALUES ("
                  + to_string(bookId) + "," + to_string(userId) + ",'" + today + "','" + R_day + "');";

    string sql2 = "UPDATE books SET isAvailable=0 WHERE bookId=" + to_string(bookId) + ";";

    if (executeSQL(sql1) && executeSQL(sql2)) {
        cout << " Book issued successfully!\n";
    } else {
        cout << " Failed to issue book!\n";
    }
}

void returnBook() {
    if (currentUser.role == "Member") { cout << "Access Denied!\n"; return; }

    int bookId;
    cout << "\nEnter Book ID to Return: "; cin >> bookId; cin.ignore();

    string today = getCurrentDate();
    string sql1 = "UPDATE transactions SET returnDate='" + today + "', isReturned=1 WHERE bookId=" + to_string(bookId) + " AND isReturned=0;";
    string sql2 = "UPDATE books SET isAvailable=1 WHERE bookId=" + to_string(bookId) + ";";

    if (executeSQL(sql1) && executeSQL(sql2))
        cout << " Book returned successfully!\n";
    else
        cout << " Failed to return book!\n";
}


                        // DELETE OPERATION
void deleteBook() {
    if (currentUser.role == "Member") {
        cout << "Access Denied!\n";
        return;
    }

    int bookId;
    cout << "\nEnter Book ID to Delete: ";
    cin >> bookId;
    cin.ignore();

    // Check if borrowed
    sqlite3_stmt* stmt = nullptr;
    string check = "SELECT COUNT(*) FROM transactions WHERE bookId = " + to_string(bookId) + " AND isReturned = 0;";
    int borrowed = 0;

    if (sqlite3_prepare_v2(db, check.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW)
            borrowed = sqlite3_column_int(stmt, 0);
    }
    if (stmt) sqlite3_finalize(stmt);

    if (borrowed > 0) {
        cout << "Cannot delete! Book is currently borrowed.\n";
        return;
    }

    string confirm;
    cout << "Are you sure you want to delete this book? (yes/no): ";
    getline(cin, confirm);

    if (confirm != "yes" && confirm != "YES") {
        cout << "Deletion cancelled.\n";
        return;
    }

    string sql = "DELETE FROM books WHERE bookId = " + to_string(bookId) + ";";
    if (executeSQL(sql))
        cout << "Book deleted successfully!\n";
    else
        cout << "Failed to delete book.\n";
}

