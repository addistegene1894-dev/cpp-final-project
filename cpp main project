using namespace std;

sqlite3* db = nullptr;

struct User {
    int userId;
    string username;
    string password;
    string role;
    string name;
};

User currentUser;

bool executeSQL(const string& sql) {
    char* errMsg = nullptr;
    int rc = sqlite3_exec(db, sql.c_str(), nullptr, nullptr, &errMsg);
    if (rc != SQLITE_OK) {
        cerr << "SQL Error: " << errMsg << endl;
        sqlite3_free(errMsg);
        return false;
    }
    return true;
}

string getCurrentDate(int add_days = 0) {
    time_t now = time(nullptr);
    now += add_days*86400;
    tm* ltm = localtime(&now);
    stringstream ss;
    ss << (1900 + ltm->tm_year) << "-"
       << setw(2) << setfill('0') << (1 + ltm->tm_mon) << "-"
       << setw(2) << setfill('0') << ltm->tm_mday;
    return ss.str();
}

// DATABASE
void initDatabase() {
    executeSQL(R"(CREATE TABLE IF NOT EXISTS users (userId INTEGER PRIMARY KEY, username TEXT UNIQUE NOT NULL, password TEXT NOT NULL, role TEXT NOT NULL, name TEXT);)");
    executeSQL(R"(CREATE TABLE IF NOT EXISTS books (bookId INTEGER PRIMARY KEY, title TEXT NOT NULL, author TEXT NOT NULL, isbn TEXT UNIQUE, isAvailable INTEGER DEFAULT 1);)");
    executeSQL(R"(CREATE TABLE IF NOT EXISTS transactions (transactionId INTEGER PRIMARY KEY, bookId INTEGER, userId INTEGER, issueDate TEXT, dueDate TEXT, returnDate TEXT, isReturned INTEGER DEFAULT 0);)");

    executeSQL("INSERT OR IGNORE INTO users (username, password, role, name) VALUES ('admin', 'admin123', 'Manager', 'Addis');");
    cout << "Database initialized successfully!\n";
}

// AUTHENTICATION
bool login() {
    string username, password;
    cout << "\n LIBRARY LOGIN \n";
    cout << "Username: "; getline(cin, username);
    cout << "Password: "; getline(cin, password);

    string sql = "SELECT * FROM users WHERE username = '" + username + "' AND password = '" + password + "';";
    sqlite3_stmt* stmt = nullptr;

    if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW) {
            currentUser.userId = sqlite3_column_int(stmt, 0);
            currentUser.username = reinterpret_cast<const char*>(sqlite3_column_text(stmt, 1));
            currentUser.role = reinterpret_cast<const char*>(sqlite3_column_text(stmt, 3));
            currentUser.name = reinterpret_cast<const char*>(sqlite3_column_text(stmt, 4));
            sqlite3_finalize(stmt);
            cout << "\n  Login Successful! Welcome, " << currentUser.name << " (" << currentUser.role << ")\n";
            return true;
        }
    }
    if (stmt) sqlite3_finalize(stmt);
    cout << "Invalid username or password!\n";
    return false;
}

void registerUser() {
    if (currentUser.role != "Manager") {
        cout << "Access Denied! Only Manager can register users.\n";
        return;
    }

    string username, pass1, pass2, role, name;
    cout << "\n Register New User \n";
    cout << "Username: "; getline(cin, username);
    cout << "Full Name: "; getline(cin, name);
    cout << "Role (Manager/Librarian/Member): "; getline(cin, role);
    cout << "Password: "; getline(cin, pass1);
    cout << "Confirm Password: "; getline(cin, pass2);

    if (pass1 != pass2) {
        cout << " Passwords do not match!\n";
        return;
    }

    string sql = "INSERT INTO users (username, password, role, name) VALUES ('" + username + "', '" + pass1 + "', '" + role + "', '" + name + "');";
    if (executeSQL(sql)) cout << "User registered successfully!\n";
else cout<<"Failed to register user(Username may already exist).\n";
}
// BORROW LIMIT
bool canBorrow(int userId) {
    const int MAX_BOOKS = 3;
    sqlite3_stmt* stmt = nullptr;
    string sql = "SELECT COUNT(*) FROM transactions WHERE userId = " + to_string(userId) + " AND isReturned = 0;";

    if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW) {
            int count = sqlite3_column_int(stmt, 0);
            sqlite3_finalize(stmt);

            if (count >= MAX_BOOKS) {
                cout << "This user has already borrowed " << count << " books (Max allowed: 3)\n";
                return false;
            }
            return true;
        }
    }
    if (stmt) sqlite3_finalize(stmt);
    return true;  // Allow if query fails (safer)
}

