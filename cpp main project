    }

    int userId;
    cout << "\nEnter User ID to Delete: ";
    cin >> userId;
    cin.ignore();

    if (userId == currentUser.userId) {
        cout << "You cannot delete your own account!\n";
        return;
    }

    // Check borrowed books
    sqlite3_stmt* stmt = nullptr;
    string check = "SELECT COUNT(*) FROM transactions WHERE userId = " + to_string(userId) + " AND isReturned = 0;";
    int borrowed = 0;

    if (sqlite3_prepare_v2(db, check.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        if (sqlite3_step(stmt) == SQLITE_ROW)
            borrowed = sqlite3_column_int(stmt, 0);
    }
    if (stmt) sqlite3_finalize(stmt);

    if (borrowed > 0) {
        cout << "Cannot delete! User has " << borrowed << " book(s) borrowed.\n";
        return;
    }

    string confirm;
    cout << "Are you sure you want to delete this user? (yes/no): ";
    getline(cin, confirm);

    if (confirm != "yes" && confirm != "YES") {
        cout << "Deletion cancelled.\n";
        return;
    }

    string sql = "DELETE FROM users WHERE userId = " + to_string(userId) + ";";
    if (executeSQL(sql))
        cout << "User deleted successfully!\n";
    else
        cout << "Failed to delete user.\n";
}

