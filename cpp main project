    cout << string(90, '-') << endl;

    string sql = R"(
        SELECT t.transactionId, t.bookId, b.title, u.name,
               CASE WHEN t.isReturned = 1 THEN 'Returned' ELSE 'Issued' END,
               COALESCE(t.returnDate, t.issueDate)
        FROM transactions t
        JOIN books b ON t.bookId = b.bookId
        JOIN users u ON t.userId = u.userId
        ORDER BY t.transactionId DESC LIMIT 30;
    )";

    sqlite3_stmt* stmt = nullptr;
    if (sqlite3_prepare_v2(db, sql.c_str(), -1, &stmt, nullptr) == SQLITE_OK) {
        bool has = false;
        while (sqlite3_step(stmt) == SQLITE_ROW) {
            has = true;
            cout << left << setw(8) << sqlite3_column_int(stmt, 0)
                 << setw(8) << sqlite3_column_int(stmt, 1)
                 << setw(30) << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 2))
                 << setw(20) << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 3))
                 << setw(12) << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 4))
                 << reinterpret_cast<const char*>(sqlite3_column_text(stmt, 5)) << endl;
        }
        if (!has) cout << "No activities yet.\n";
    }
    if (stmt) sqlite3_finalize(stmt);
}

void viewAllUsers() {
    if (currentUser.role == "Member") { cout << "Access Denied!\n"; return; }

    cout << "\n ALL USERS \n";
    cout << left << setw(6) << "ID" << setw(25) << "Name" << setw(15) << "Role"
         << setw(10) << "Borrowed\n";
    cout << string(60, '-') << endl;

    sqlite3_stmt* stmt = nullptr;
    if (sqlite3_prepare_v2(db, "SELECT userId, name, role FROM users;", -1, &stmt, nullptr) == SQLITE_OK) {
        while (sqlite3_step(stmt) == SQLITE_ROW) {
            int uid = sqlite3_column_int(stmt, 0);
            string name = reinterpret_cast<const char*>(sqlite3_column_text(stmt, 1));
            string role = reinterpret_cast<const char*>(sqlite3_column_text(stmt, 2));

            sqlite3_stmt* cstmt = nullptr;
            int borrowed = 0;
            string csql = "SELECT COUNT(*) FROM transactions WHERE userId=" + to_string(uid) + " AND isReturned=0;";
            if (sqlite3_prepare_v2(db, csql.c_str(), -1, &cstmt, nullptr) == SQLITE_OK) {
                if (sqlite3_step(cstmt) == SQLITE_ROW) borrowed = sqlite3_column_int(cstmt, 0);
            }
            if (cstmt) sqlite3_finalize(cstmt);

            cout << left << setw(6) << uid << setw(25) << name << setw(15) << role
                 << setw(10) << borrowed << endl;
        }
    }
    if (stmt) sqlite3_finalize(stmt);
}


// MENU
void showMenu() {
    while (true) {
        cout << "\n LIBRARY MANAGEMENT SYSTEM \n";
        cout << "Logged in as: " << currentUser.name << " (" << currentUser.role << ")\n";
        cout << string(50, '-') << "\n";

        cout << "1. View All Books\n";
        cout << "2. Search Book\n";

        if (currentUser.role != "Member") {
            cout << "3. Add Book\n";
            cout << "4. Issue Book\n";
            cout << "5. Return Book\n";
            cout<< "6. Delete Book\n";
            cout << "7. View All Users\n";
        }

        if (currentUser.role == "Manager") {
            cout << "8. Register New User\n";
            cout<<"9. Delete User\n";
            cout << "10. View 30 Recent Activities\n";
        }

        cout << "0. Logout\n";
        cout << "99. Exit Program\n";
        cout << "Choice: ";

        int choice;
        cin >> choice;
        cin.ignore();

        switch (choice) {
            case 1: viewAllBooks(); break;
            case 2: searchBook(); break;
            case 3: addBook(); break;
            case 4: issueBook(); break;
            case 5: returnBook(); break;
            case 6:deleteBook();break;
            case 7: viewAllUsers(); break;
            case 8: registerUser(); break;
            case 9:deleteUser();break;
            case 10: viewRecentActivities(); break;
            case 0:
                cout << "\nLogging out...\n";
                return;
            case 99:
                cout << "Thank you! Goodbye.\n";
                sqlite3_close(db);
                exit(0);
            default:
                cout << "Invalid choice!\n";
        }
    }
}


